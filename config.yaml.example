openai_api_key: ""          # Or use OPENAI_API_KEY env var
telegram_bot_token: ""      # Or use TELEGRAM_BOT_TOKEN env var
telegram_user_id: 0         # Your numerical Telegram user ID. Or use TELEGRAM_USER_ID env var
model_name: "gpt-4.1-mini"  # Or use MODEL_NAME env var
max_summary_sentences: 5
data_dir: "data"            # Or use DATA_DIR env var (e.g. /data for a Railway volume)
log_level: "INFO"           # Or use LOG_LEVEL env var

# Brain / knowledge vault settings
brain_dir: "data/obsidian-brain"    # Optional. Defaults to <data_dir>/obsidian-brain, which stays gitignored.
skills_enabled: false                # Optional. Or use SKILLS_ENABLED env var to generate Claude Code artifacts in the same repo.
skills_dir: "data/obsidian-brain/Claude-Code"  # Optional. Defaults to <brain_dir>/Claude-Code. Or use SKILLS_DIR env var.
digest_sources_file: "digest_sources.txt"  # Or use DIGEST_SOURCES_FILE env var
digest_schedule: "07:00"            # UTC time for daily digest (HH:MM). Or use DIGEST_SCHEDULE env var
git_remote: "origin"                # Git remote inside the dedicated brain repo. Or use GIT_REMOTE env var
git_branch: "master"                # Git branch to push to. Or use GIT_BRANCH env var

# Brain runtime env vars (Railway / containers — set as env vars, not here):
#   BRAIN_ENABLED      "false" to disable brain features entirely (link saving still works)
#   GITHUB_TOKEN       Personal access token with `repo` scope, used to push brain commits
#   GIT_REPO_SLUG      e.g. "youruser/linkstash-brain" — private repo used for the brain vault
#   GIT_USER_EMAIL     Committer email (default: linkstash-bot@users.noreply.github.com)
#   GIT_USER_NAME      Committer name  (default: LinkStash Bot)
#   SKILLS_ENABLED     true/false toggle for Claude Code artifact generation
#   SKILLS_DIR         override the Claude artifact root path inside the brain repo

# Categories used for link classification.
# Edit freely — these are passed to the LLM as the allowed output values.
categories:
  - "ML General"
  - "AI Training & Fine-tuning"
  - "Research & Papers"
  - "AI Tools & Open Source"
  - "Hardware & Computing"
  - "Personal Productivity"
  - "Uncategorized"
